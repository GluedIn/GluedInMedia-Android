<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/placeholder"
            android:layout_width="@dimen/gi_dp108"
            android:layout_height="@dimen/gi_dp190"
            app:actualImageScaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:placeholderImage="@drawable/gi_vertical_video_thumbnail"
            app:placeholderImageScaleType="fitXY" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/series_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/gi_dp2"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/gi_ic_discover_series" />

        <com.gluedin.base.presentation.customView.GluedInSemiboldTextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha=".9"
            android:background="@color/black"
            android:ellipsize="end"
            android:gravity="start|center"
            android:maxLines="2"
            android:minLines="2"
            android:paddingHorizontal="@dimen/gi_dp6"
            android:paddingVertical="@dimen/gi_dp2"
            android:textColor="@color/white"
            android:textSize="@dimen/gi_sp10"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:lineHeight="@dimen/gi_sp12"
            tools:text="The Silent Betrayal asdf" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>